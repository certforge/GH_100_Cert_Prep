# EditorConfig — https://editorconfig.org
# Ensures consistent coding styles across editors and IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
# Markdown: trailing whitespace is significant (two spaces = line break)
trim_trailing_whitespace = false
indent_size = 2
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.sh]
indent_size = 2
shell_variant = bash

[*.py]
indent_size = 4

[Makefile]
indent_style = tab

[*.{bat,cmd}]
end_of_line = crlf
